# env.sops.yaml.example
#
# Rename this to env.sops.yaml and encrypt it with:
#
#   mv env.sops.yaml.example env.sops.yaml
#   sops -e -i env.sops.yaml
#
# Or, simpler — let sops create the file interactively:
#
#   sops env.sops.yaml
#   (edit: flat KEY: value map, save, sops re-encrypts on save)
#
# Format: a single flat YAML map. Values become `export KEY=value`
# lines in $CLAUDE_ENV_FILE at session start. No nesting, no lists.

ANTHROPIC_API_KEY: "sk-ant-REPLACE-ME"
GITHUB_MCP_TOKEN:  "ghp_REPLACE_ME"
OPENAI_API_KEY:    "sk-REPLACE_ME"

# MCP server env vars — named the same way the MCP config expects them
# so the server inherits them from the parent process.
BRAVE_SEARCH_API_KEY: "REPLACE_ME"
EXA_API_KEY:          "REPLACE_ME"
