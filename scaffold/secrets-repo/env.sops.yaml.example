# env.sops.yaml.example
#
# Rename this to env.sops.yaml and encrypt it with:
#
#   mv env.sops.yaml.example env.sops.yaml
#   sops -e -i env.sops.yaml
#
# Or, simpler — let sops create the file interactively:
#
#   sops env.sops.yaml
#   (edit: flat KEY: value map, save, sops re-encrypts on save)
#
# Format: a single flat YAML map. Values become `export KEY=value`
# lines in $CLAUDE_ENV_FILE at session start. No nesting, no lists.
#
# IMPORTANT: name each variable EXACTLY as the consuming MCP server
# expects to read it. That way the server inherits it from the session
# env with no translation needed. See claude/mcp/servers/*.json in
# Monty-CNS for the correct name per server.

# Anthropic API (optional — Claude Code has its own auth)
ANTHROPIC_API_KEY: "sk-ant-REPLACE-ME"

# GitHub MCP server expects this exact name
GITHUB_PERSONAL_ACCESS_TOKEN: "ghp_REPLACE_ME"

# OpenAI API (if you use MCP servers that talk to OpenAI)
OPENAI_API_KEY: "sk-REPLACE_ME"

# Search MCP servers — exact names per server
BRAVE_SEARCH_API_KEY: "REPLACE_ME"
EXA_API_KEY:          "REPLACE_ME"
