# --- Secrets (NEVER commit) ---
.credentials.json
**/.credentials.json
*.pem
*.key
.env
.env.*
!.env.example

# --- Auto-generated session state (PreCompact hook, /learn, /brief) ---
CHECKPOINT.md
docs/CHECKPOINT.md
.claude/CHECKPOINT.md
LEARNINGS.md
.claude/LEARNINGS.md
briefings/
.claude/briefings/

# --- Claude runtime / machine-local state ---
# These live under ~/.claude on each host and should stay local.
claude/projects/
claude/sessions/
claude/session-env/
claude/todos/
claude/statsig/
claude/shell-snapshots/
claude/backups/
claude/.claude.json
claude/.claude.json.backup
claude/ide/
claude/logs/

# --- MCP server local state ---
claude/mcp/**/state/
claude/mcp/**/cache/
claude/mcp/**/*.sqlite*
claude/mcp/**/node_modules/
# File-based secrets decrypted at runtime — plaintext, 0600, NEVER commit
claude/mcp/keys/
claude/mcp/keys/**

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
